generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Seed: npm run db:seed
//
// Score scales (important for reports/winner logic):
// - topicScore, reviewScore, avgReviewScore: 0..1 (0=worst, 1=best)


model Job {
  id             String    @id @default(uuid())
  traceId        String    @map("trace_id")
  status         String    @db.VarChar(32)
  decision       String?   @db.VarChar(32)
  sourceType     String    @map("source_type") @db.VarChar(32)
  topicScore     Decimal?  @map("topic_score") @db.Decimal(5, 4)  // 0..1
  reviewScore    Decimal?  @map("review_score") @db.Decimal(5, 4)  // 0..1
  retryCount     Int       @default(0) @map("retry_count")
  idempotencyKey String?   @unique @map("idempotency_key") @db.VarChar(255)
  createdAt      DateTime  @default(now()) @map("created_at")
  completedAt    DateTime? @map("completed_at")

  inputs          JobInput?
  outputs         JobOutput?
  approvals       Approval[]
  published       PublishedContent[]
  snapshots       JobStateSnapshot[]
  contentVersions ContentVersion[]
  metrics         ContentMetric[]
  trendTopicObservations TrendTopicObservation[]
  /// Bản ghi output chính thức của content pipeline (1:1 job); đồng bộ khi graph hoàn thành.
  contentDraft    ContentDraft?
}

/// Append-only per completed trend job slot; used for cross-job topic dedup / admin library.
model TrendTopicObservation {
  id             String   @id @default(uuid())
  fingerprint    String   @db.VarChar(64)
  trendDomain    String   @map("trend_domain") @db.VarChar(64)
  sourceJobId    String   @map("source_job_id")
  candidateIndex Int      @map("candidate_index")
  topicTitle     String   @map("topic_title") @db.VarChar(512)
  createdAt      DateTime @default(now()) @map("created_at")

  job Job @relation(fields: [sourceJobId], references: [id], onDelete: Cascade)

  @@index([fingerprint])
  @@index([sourceJobId])
  @@index([trendDomain])
  @@map("trend_topic_observation")
}

/// Bài crawl / RSS lưu theo khóa ổn định; tránh đưa cùng một bài vào trend job lặp trong cửa sổ thời gian.
model CrawledArticle {
  id                  String    @id @default(uuid())
  dedupeKey           String    @unique @map("dedupe_key") @db.VarChar(64)
  trendDomain         String    @map("trend_domain") @db.VarChar(64)
  url                 String?   @db.VarChar(2048)
  title               String    @db.VarChar(512)
  bodyPreview         String?   @map("body_preview") @db.Text
  sourceId            String?   @map("source_id") @db.VarChar(128)
  rawPayload          Json?     @map("raw_payload")
  firstSeenAt         DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt          DateTime  @updatedAt @map("last_seen_at")
  processedForTrendAt DateTime? @map("processed_for_trend_at")

  @@index([trendDomain])
  @@index([processedForTrendAt])
  @@map("crawled_article")
}

model JobInput {
  jobId             String   @id @map("job_id")
  rawPayload        Json     @map("raw_payload")
  normalizedPayload Json     @map("normalized_payload")
  updatedAt         DateTime @updatedAt @map("updated_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model JobOutput {
  jobId                  String   @id @map("job_id")
  outline                String?  @db.Text
  draft                  String?  @db.Text
  reviewNotes            String?  @map("review_notes") @db.Text
  finalDecisionPayload   Json?    @map("final_decision_payload")
  promptVersions         Json?    @map("prompt_versions")
  experimentAssignments  Json?    @map("experiment_assignments")
  trendCandidates        Json?    @map("trend_candidates")
  updatedAt              DateTime @updatedAt @map("updated_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

/// Entity draft: snapshot outline + body + review khi content graph xong (khác trend_aggregate).
model ContentDraft {
  id          String    @id @default(uuid())
  jobId       String    @unique @map("job_id")
  outline     String?   @db.Text
  body        String?   @db.Text
  reviewNotes String?   @map("review_notes") @db.Text
  decision    String?   @db.VarChar(32)
  topicScore  Decimal?  @map("topic_score") @db.Decimal(5, 4)
  reviewScore Decimal?  @map("review_score") @db.Decimal(5, 4)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("content_draft")
}

model ContentVersion {
  id          String   @id @default(uuid())
  jobId       String   @map("job_id")
  version     Int      @default(1)
  draft       String?  @db.Text
  reviewScore Decimal? @map("review_score") @db.Decimal(5, 4)
  createdAt   DateTime @default(now()) @map("created_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, version])
  @@index([jobId])
}

model JobStateSnapshot {
  id        String   @id @default(uuid())
  jobId     String   @map("job_id")
  step      String   @db.VarChar(64)
  stateJson Json     @map("state_json")
  createdAt DateTime @default(now()) @map("created_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([jobId, step])
}

model Approval {
  id        String   @id @default(uuid())
  jobId     String   @map("job_id")
  action    String   @db.VarChar(32)
  actor     String   @db.VarChar(128)
  reason    String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  job Job @relation(fields: [jobId], references: [id])
}

model PublishedContent {
  id          String    @id @default(uuid())
  jobId       String    @map("job_id")
  channelId   String    @map("channel_id") @db.VarChar(128)
  status      String    @db.VarChar(32)
  publishRef  String?   @map("publish_ref") @db.VarChar(255)
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  job Job @relation(fields: [jobId], references: [id])
}

model ContentMetric {
  id              String   @id @default(uuid())
  jobId           String   @map("job_id")
  channelId       String   @map("channel_id") @db.VarChar(128)
  topicKey        String?  @map("topic_key") @db.VarChar(255)
  topicLabel      String?  @map("topic_label") @db.VarChar(512)
  topicSignature  String?  @map("topic_signature") @db.VarChar(64)
  impressions     Int      @default(0)
  views           Int      @default(0)
  clicks          Int      @default(0)
  avgReviewScore  Decimal?  @map("avg_review_score") @db.Decimal(5, 4)  // 0..1
  recordedAt      DateTime @default(now()) @map("recorded_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, channelId])
  @@index([topicKey])
  @@index([topicSignature])
  @@index([jobId])
}

model DailyTopicMetric {
  id              String   @id @default(uuid())
  topicKey        String   @map("topic_key") @db.VarChar(255)
  topicSignature  String   @default("") @map("topic_signature") @db.VarChar(64)
  metricDate      DateTime @map("metric_date") @db.Date
  avgCtr          Decimal  @map("avg_ctr") @db.Decimal(10, 6)
  sampleCount     Int      @map("sample_count")
  avgReviewScore  Decimal? @map("avg_review_score") @db.Decimal(5, 4)  // 0..1
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([topicKey, topicSignature, metricDate])
  @@index([topicKey])
  @@index([topicSignature])
  @@index([metricDate])
}

model PromptVersion {
  id        String   @id @default(uuid())
  type      String   @db.VarChar(64)
  version   Int      @default(1)
  content   String   @db.Text
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([type, version])
  @@index([type])
}

// A/B experiments
model Experiment {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  nodeType    String   @map("node_type") @db.VarChar(32)
  scope       String   @db.VarChar(32)
  scopeValue  String?  @map("scope_value") @db.VarChar(255)
  status      String   @default("draft") @db.VarChar(32)
  numBuckets  Int      @default(100) @map("num_buckets")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  arms    ExperimentArm[]
  results ExperimentResultsDaily[]

  @@index([nodeType])
  @@index([status])
  @@index([nodeType, status])
}

model ExperimentArm {
  id           String   @id @default(uuid())
  experimentId String   @map("experiment_id")
  name         String   @db.VarChar(64)
  promptType   String   @map("prompt_type") @db.VarChar(64)
  promptVersion Int     @map("prompt_version")
  bucketStart   Int     @map("bucket_start")
  bucketEnd     Int     @map("bucket_end")
  createdAt     DateTime @default(now()) @map("created_at")

  experiment Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  results   ExperimentResultsDaily[]

  @@unique([experimentId, name])
  @@index([experimentId])
}

model ExperimentResultsDaily {
  id                 String   @id @default(uuid())
  experimentId       String   @map("experiment_id")
  armId              String   @map("arm_id")
  metricDate         DateTime @map("metric_date") @db.Date
  jobsCount          Int      @default(0) @map("jobs_count")
  approvedCount      Int      @default(0) @map("approved_count")
  reviewRequiredCount Int     @default(0) @map("review_required_count")
  rejectedCount      Int      @default(0) @map("rejected_count")
  impressions        Int      @default(0)
  views              Int      @default(0)
  clicks             Int      @default(0)
  avgReviewScore     Decimal? @map("avg_review_score") @db.Decimal(5, 4)  // 0..1
  smoothedCtr        Decimal? @map("smoothed_ctr") @db.Decimal(10, 6)
  sampleCount        Int      @default(0) @map("sample_count")
  updatedAt          DateTime @updatedAt @map("updated_at")

  experiment Experiment   @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  arm        ExperimentArm @relation(fields: [armId], references: [id], onDelete: Cascade)

  @@unique([experimentId, armId, metricDate])
  @@index([experimentId])
  @@index([metricDate])
}
