# Copy to .env.langfuse and set secrets before: docker compose -f docker-compose.langfuse.yml --env-file .env.langfuse up -d
# NEXTAUTH_SECRET + SALT: openssl rand -base64 32  (mỗi biến một giá trị riêng; không dùng mật khẩu ngắn — NextAuth sẽ login failed)
# ENCRYPTION_KEY: openssl rand -hex 32

LANGFUSE_NEXTAUTH_URL=http://localhost:3030
NEXTAUTH_SECRET=CHANGEME_use_openssl_rand_base64_32

LANGFUSE_DATABASE_URL=postgresql://postgres:postgres@langfuse-postgres:5432/postgres
POSTGRES_PASSWORD=postgres

SALT=CHANGEME_use_openssl_rand_base64_32
ENCRYPTION_KEY=CHANGEME_64_hex_chars_openssl_rand_hex_32

CLICKHOUSE_PASSWORD=clickhouse

REDIS_AUTH=myredissecret

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=CHANGEME

LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}

TELEMETRY_ENABLED=false

# Seed user/org/project: BẮT BUỘC LANGFUSE_INIT_ORG_ID (UUID). Không set → Langfuse bỏ qua mọi INIT_* (kể cả user/password).
# LANGFUSE_INIT_ORG_ID=
# LANGFUSE_INIT_PROJECT_ID=
# LANGFUSE_INIT_ORG_NAME=My Org
# LANGFUSE_INIT_PROJECT_NAME=default
# LANGFUSE_INIT_USER_EMAIL=
# LANGFUSE_INIT_USER_NAME=
# LANGFUSE_INIT_USER_PASSWORD=
# LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
# LANGFUSE_INIT_PROJECT_SECRET_KEY=
