# Server
PORT=3000
NODE_ENV=development

# Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/content_company

# Redis
REDIS_URL=redis://localhost:6380

# API Auth (bearer token for n8n/orchestrator calls)
API_KEY=your-secret-api-key

# n8n (for npm run n8n:import - clean + import workflows)
N8N_URL=http://localhost:5678
N8N_API_KEY=

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL_PRIMARY=gpt-4o-mini
OPENAI_MODEL_FALLBACK=gpt-3.5-turbo

# Langfuse (optional — tracing + cost in Langfuse UI; omit keys to disable)
# Self-host: docker-compose.langfuse.yml + .env.langfuse — UI http://localhost:3030
# Cloud: LANGFUSE_HOST=https://cloud.langfuse.com
# Code uses LANGFUSE_HOST only (not LANGFUSE_BASE_URL)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3030
# Browser URL for Admin “Open Langfuse” (set if LANGFUSE_HOST is Docker-internal)
# LANGFUSE_UI_PUBLIC_URL=http://localhost:3030

# Trend aggregate: optional embedding merge after Jaccard (OpenAI embeddings API)
# TREND_EMBEDDING_REFINE=0 to disable. TREND_EMBEDDING_STORE=off|preview|full (default preview)
# TREND_MIN_SOURCES=2 (default) — set 1 chỉ khi muốn mỗi bài một dòng (không còn nghĩa trend chung)
# TREND_ITEM_SEMANTIC_CLUSTER=1 (default) — Jaccard + cosine embedding title; =0 chỉ Jaccard
# TREND_ITEM_COSINE_THRESHOLD=0.8
# TREND_EMBEDDING_REFINE=1
# TREND_EMBEDDING_MERGE_THRESHOLD=0.85
# TREND_EMBEDDING_MODEL=text-embedding-3-small
# TREND_EMBEDDING_STORE=preview

# Queue (BullMQ): set USE_QUEUE=1 for async processing (API enqueues, worker runs graph)
USE_QUEUE=0

# Optional: n8n workflow "D - Publish to Webhook" — receiver that accepts JSON (jobId, draft, outline, …)
# Pass through docker-compose to the n8n service: PUBLISH_WEBHOOK_URL=https://your-hook.example/post
# PUBLISH_WEBHOOK_URL=
