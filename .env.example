# Server
PORT=3000
NODE_ENV=development

# Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/content_company

# Redis
REDIS_URL=redis://localhost:6380

# API Auth (bearer token for n8n/orchestrator calls)
API_KEY=your-secret-api-key

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL_PRIMARY=gpt-4o-mini
OPENAI_MODEL_FALLBACK=gpt-3.5-turbo

# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Queue (BullMQ): set USE_QUEUE=1 for async processing (API enqueues, worker runs graph)
USE_QUEUE=0
